{
  "name": "zelda-database",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://purplehato.github.io/HM64-DB",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "predeploy": "npm run build && node -e \"const fs=require('fs');fs.existsSync('build/data')&&fs.rmSync('build/data',{recursive:true,force:true});fs.cpSync('data','build/data',{recursive:true})\"",
    "deploy": "gh-pages -d build"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.85.5",
    "@tanstack/react-query-devtools": "^5.85.5",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "autoprefixer": "^10.4.27",
    "clsx": "^2.1.1",
    "fast-xml-parser": "^5.4.1",
    "gh-pages": "^6.3.0",
    "postcss": "^8.5.6",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.2",
    "vite": "^7.3.1"
  }
}
